# ============================================================
# NongNghiepAI Docker environment example
# Copy file này thành `.env` trước khi chạy `docker compose up --build`.
# Không điền/commit API key thật vào `.env.example`.
# ============================================================

# --- Compose / ports ---
COMPOSE_PROJECT_NAME=nongnghiepai
FRONTEND_PORT=5173
BACKEND_PORT=8000
MSSQL_PORT=1433
REDIS_PORT=6379

# --- SQL Server container ---
MSSQL_PID=Express
MSSQL_DATABASE=NongNghiepAI
MSSQL_SA_PASSWORD=YourStrongPassword123!
FORCE_DB_INIT=false

# Backend dùng tên service `database`, không dùng localhost trong Docker.
DATABASE_URL=mssql+pymssql://sa:YourStrongPassword123!@database:1433/NongNghiepAI
SQLITE_FALLBACK_ENABLED=false
REDIS_URL=redis://redis:6379/0

# --- Backend app ---
ENVIRONMENT=docker
SECRET_KEY=change-me-docker-secret-key-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
UPLOAD_DIR=storage/uploads
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend:5173
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# --- Frontend / Vite ---
# Để trống để browser gọi `/api/...` qua Vite proxy; proxy trong container gọi `http://backend:8000`.
VITE_API_BASE_URL=
VITE_API_URL=
VITE_BACKEND_PROXY_URL=http://backend:8000
VITE_API_TIMEOUT_MS=18000
VITE_AI_TIMEOUT_MS=60000
VITE_UPLOAD_TIMEOUT_MS=60000

# --- Data policy ---
# Docker mặc định không dùng dữ liệu mock/sample khi API/database lỗi.
ALLOW_MOCK_DATA=false
ALLOW_SAMPLE_DATA=false
USE_REALTIME_ONLY=true

# --- AI / LLM APIs ---
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL_NAME=gemini-2.5-flash
AI_TIMEOUT_SECONDS=45
CLAUDE_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Tavily news/search ---
TAVILY_API_KEY=
TAVILY_ENABLED=false
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=10
TAVILY_NEWS_CACHE_TTL_MINUTES=120

# --- Weather ---
WEATHER_PROVIDER=open-meteo
WEATHER_API_KEY=
WEATHER_API_BASE_URL=
OPEN_METEO_BASE_URL=https://api.open-meteo.com
WEATHER_CACHE_TTL_SECONDS=1800
WEATHER_TIMEOUT_SECONDS=8
WEATHER_CONNECT_TIMEOUT_SECONDS=3
WEATHER_READ_TIMEOUT_SECONDS=6
WEATHER_RETRY_COUNT=1

# --- Market price / news sources ---
WINMART_ENABLED=true
WINMART_API_BASE_URL=https://api-crownx.winmart.vn
WINMART_ITEM_SEARCH_ENDPOINT=/ss/api/v2/public/winmart/item-search
WINMART_STORE_NO=1535
WINMART_STORE_GROUP_CODE=1998
WINMART_APPLICATION_TYPE=Winmart
WINMART_SOURCE_URL=https://winmart.vn/
PRICE_SOURCE_URLS_JSON=[{"name":"WinMart","url":"https://winmart.vn/"}]
RETAIL_PRICE_SOURCES_JSON=[{"name":"WinMart","url":"https://winmart.vn/"}]

THITRUONG_NONGSAN_PRICE_URL=https://thitruongnongsan.gov.vn/vn/nguonwmy.aspx
THITRUONG_NONGSAN_NEWS_URL=https://thitruongnongsan.gov.vn/vn/xc0_tin-tuc.html
ENABLE_THITRUONG_NONGSAN_PRICE=false
ENABLE_THITRUONG_NONGSAN_NEWS=true
THITRUONGNONGSAN_BASE_URL=https://thitruongnongsan.gov.vn
THITRUONGNONGSAN_ENABLED=true

MARKET_API_BASE_URL=
MARKET_PRICE_API_URL=
MARKET_PRICE_API_KEY=
ENABLE_REALTIME_PRICE=true
ENABLE_MARKET_NEWS=true
ENABLE_STOOQ_PRICE_SOURCE=false
PRICE_CACHE_TTL_MINUTES=60
NEWS_CACHE_TTL_MINUTES=120
MARKET_NEWS_CACHE_TTL_SECONDS=1800
MARKET_NEWS_RSS_URLS_JSON=["https://vnexpress.net/rss/kinh-doanh.rss","https://vnexpress.net/rss/tin-moi-nhat.rss"]
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
USD_VND_FALLBACK_RATE=26000

# --- Optional external market APIs ---
APIFARMER_API_BASE_URL=
APIFARMER_API_KEY=
APIFARMER_ENABLED=false
APIFARMER_PRICE_ENDPOINT=/prices/current
APIFARMER_HISTORY_ENDPOINT=
APIFARMER_NEWS_ENDPOINT=/news
TWELVEDATA_API_BASE_URL=https://api.twelvedata.com
TWELVEDATA_API_KEY=
TWELVEDATA_ENABLED=false
TWELVEDATA_PRICE_ENDPOINT=/price
TWELVEDATA_TIME_SERIES_ENDPOINT=/time_series
TWELVEDATA_NEWS_ENDPOINT=

# --- Background jobs ---
REAL_REFRESH_ENABLED=false
REAL_REFRESH_STARTUP_DELAY_SECONDS=10
REAL_REFRESH_STAGGER_SECONDS=45
REAL_REFRESH_REGIONS=Ha Noi,TP.HCM,Da Nang,Can Tho,Lam Dong,Dak Lak
REAL_REFRESH_CROPS=lua,ca phe,ho tieu,rau,ca chua
WEATHER_CURRENT_REFRESH_SECONDS=1200
WEATHER_HOURLY_REFRESH_SECONDS=1800
WEATHER_FORECAST_REFRESH_SECONDS=7200
OFFICIAL_PRICE_REFRESH_SECONDS=7200
MARKET_NEWS_REFRESH_SECONDS=7200
RETAIL_PRICE_REFRESH_SECONDS=14400
MARKET_ANALYSIS_REFRESH_SECONDS=2700
CRAWL_INTERVAL_SECONDS=3600
CRAWL_STARTUP_DELAY_SECONDS=60
ALERT_CHECK_INTERVAL_SECONDS=3600
ALERT_CHECK_ON_STARTUP=false

# --- External request resilience ---
EXTERNAL_CONNECT_TIMEOUT_SECONDS=3
EXTERNAL_READ_TIMEOUT_SECONDS=8
EXTERNAL_WRITE_TIMEOUT_SECONDS=10
EXTERNAL_POOL_TIMEOUT_SECONDS=5
EXTERNAL_TOTAL_TIMEOUT_SECONDS=12
EXTERNAL_RETRY_COUNT=1
EXTERNAL_BACKOFF_SECONDS=0.4

# --- Notification channels (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
ZALO_OA_TOKEN=
ZALO_OA_ID=
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_API_BASE_URL=https://openapi.zalo.me
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRAND_NAME=AgriAI
ESMS_SMS_TYPE=2

# --- Model paths ---
YOLO_MODEL_PATH=ai_models/weights/best.pt
PRICE_MODEL_PATH=ai_models/price_forecast/saved_models
HARVEST_MODEL_PATH=ai_models/harvest_forecast/saved_models
