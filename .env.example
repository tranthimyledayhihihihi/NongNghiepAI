# Database
DATABASE_URL=mssql+pyodbc://sa:YourStrongPassword123!@db:1433/NongNghiepAI?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS / frontend
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
VITE_API_URL=http://localhost:8000

# Environment
ENVIRONMENT=development

# Weather
WEATHER_PROVIDER=open-meteo
WEATHER_API_BASE_URL=https://api.open-meteo.com
OPEN_METEO_BASE_URL=https://api.open-meteo.com
WEATHER_CACHE_TTL_SECONDS=1800
WEATHER_TIMEOUT_SECONDS=4
WEATHER_RETRY_COUNT=1
WEATHER_API_KEY=
REGION_COORDINATES_JSON={"Ha Noi":{"latitude":21.0285,"longitude":105.8542},"TP.HCM":{"latitude":10.8231,"longitude":106.6297},"Da Nang":{"latitude":16.0544,"longitude":108.2022},"Can Tho":{"latitude":10.0452,"longitude":105.7469},"Lam Dong":{"latitude":11.9404,"longitude":108.4583},"Hai Phong":{"latitude":20.8449,"longitude":106.6881}}

# AI
AI_PROVIDER=claude
AI_API_KEY=
AI_MODEL_NAME=claude-3-5-sonnet-latest
AI_TIMEOUT_SECONDS=20
GEMINI_API_KEY=
CLAUDE_API_KEY=
TAVILY_API_KEY=

# Price/news ingestion
PRICE_SOURCE_URLS_JSON=[{"name":"agro.gov.vn","url":"https://agro.gov.vn/index.aspx"},{"name":"agro.gov.vn-gia","url":"https://agro.gov.vn/vn/nguonwmy.aspx"}]
MARKET_API_BASE_URL=
ALERT_CHECK_INTERVAL_SECONDS=3600
ALERT_CHECK_ON_STARTUP=false
ENABLE_STOOQ_PRICE_SOURCE=true
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
USD_VND_FALLBACK_RATE=26000
MARKET_NEWS_RSS_URLS_JSON=["https://vnexpress.net/rss/kinh-doanh.rss","https://vnexpress.net/rss/tin-moi-nhat.rss"]
MARKET_NEWS_CACHE_TTL_SECONDS=1800

# Notification providers
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
ZALO_OA_TOKEN=
ZALO_OA_ID=
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_API_BASE_URL=https://openapi.zalo.me

# Models / storage
UPLOAD_DIR=storage/uploads
YOLO_MODEL_PATH=ai_models/weights/best.pt
PRICE_MODEL_PATH=ai_models/price_forecast/saved_models
HARVEST_MODEL_PATH=ai_models/harvest_forecast/saved_models
